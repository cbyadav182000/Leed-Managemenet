# ===========================
# MongoDB Configuration
# ===========================
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=leadmanagement

# ===========================
# Email Configuration (Resend)
# ===========================
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=Lead Management System

# ===========================
# Application URLs
# ===========================
# Backend public URL (used for tracking pixel & click tracking)
API_BASE_URL=http://localhost:8000
# Frontend URL (used for CORS)
CLIENT_URL=http://localhost:3000
# Where to redirect after a tracked link click
CLICK_REDIRECT_URL=https://google.com

# ===========================
# Security
# ===========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ===========================
# AI Classification (Google Gemini)
# ===========================
# Get free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_PER_MINUTE=10
